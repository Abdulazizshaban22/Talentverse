{
  "title": "System Health",
  "panels": [
    {
      "type": "graph",
      "title": "API latency p95",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "5xx errors",
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{code=~\"5..\"}[5m]))"
        }
      ]
    }
  ]
}