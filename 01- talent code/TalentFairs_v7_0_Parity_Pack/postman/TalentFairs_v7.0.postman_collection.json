{
  "info": {
    "name": "TalentFairs v7.0 Parity Pack",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "API",
      "value": "http://localhost:4000"
    }
  ],
  "item": [
    {
      "name": "Create Post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"authorId\": \"demo\", \"text\": \"\\u0645\\u0631\\u062d\\u0628\\u0627 \\u062a\\u0627\\u0644\\u0646\\u062a \\u0641\\u064a\\u0631\\u0633!\"}"
        },
        "url": "{{API}}/social/post"
      }
    },
    {
      "name": "Feed",
      "request": {
        "method": "GET",
        "url": "{{API}}/social/feed?viewerId=demo"
      }
    },
    {
      "name": "Follow",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"userId\": \"demo\", \"targetId\": \"u2\"}"
        },
        "url": "{{API}}/social/follow"
      }
    },
    {
      "name": "Endorse",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"targetId\": \"u2\", \"skill\": \"Next.js\"}"
        },
        "url": "{{API}}/social/endorse"
      }
    },
    {
      "name": "Recruiter Search",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"query\": \"az\", \"skills\": [\"Next.js\"]}"
        },
        "url": "{{API}}/biz/recruiter/search"
      }
    },
    {
      "name": "Create Course",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"title\": \"Intro to Data Skills\", \"about\": \"Foundation\", \"price\": 99}"
        },
        "url": "{{API}}/lms/course"
      }
    },
    {
      "name": "List Courses",
      "request": {
        "method": "GET",
        "url": "{{API}}/lms/course/list"
      }
    },
    {
      "name": "Issue OpenBadge",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"badgeId\": \"Data-101\", \"recipient\": \"user@example.com\"}"
        },
        "url": "{{API}}/credentials/openbadges/assertion"
      }
    },
    {
      "name": "Search Index",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"type\": \"people\", \"doc\": {\"id\": \"u9\", \"name\": \"Laila\", \"skills\": [\"Python\", \"Data\"]}}"
        },
        "url": "{{API}}/search/index"
      }
    },
    {
      "name": "Search Query",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"type\": \"people\", \"q\": \"Data\"}"
        },
        "url": "{{API}}/search/query"
      }
    }
  ]
}