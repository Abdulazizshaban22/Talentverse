DATABASE_URL=postgresql://postgres:postgres@localhost:5432/talent?schema=public

# Auth (Keycloak)
KEYCLOAK_ISSUER=http://localhost:8080/realms/talent
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/talent/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=web

# Keycloak Admin (for AuthZ sync)
KC_ADMIN_URL=http://localhost:8080
KC_REALM=talent
KC_ADMIN_CLIENT_ID=admin-cli
KC_ADMIN_CLIENT_SECRET=not-needed-for-admin-cli
KC_USER=admin
KC_PASS=admin

# Ports
PORT_API=4000
PORT_WEB=3000

# Ranker
AI_MATCH_URL=http://localhost:8600
COMBINE_W_GRAPH=0.5
COMBINE_W_LTR=0.5
USE_PAGERANK=true

# Payments
STRIPE_SIGNING_SECRET=whsec_xxx
HYPERPAY_ENTITY_ID=8ac7a4c170e1xxxxxx
HYPERPAY_ACCESS_TOKEN=Bearer OGE...
HYPERPAY_TEST_MODE=true
TAP_SECRET_KEY=sk_test_xxx
TAP_PUBLIC_KEY=pk_test_xxx
TAP_RETURN_URL=http://localhost:3000/payments/tap/return
TAP_ENABLE_GOOGLE_PAY=true

# Neo4j (GDS)
NEO4J_URL=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=pass
NEO4J_DATABASE=neo4j
NEO4J_JOB_LABEL=Job
NEO4J_JOB_ID_KEY=id
NEO4J_PAGERANK_PROP=pagerank
