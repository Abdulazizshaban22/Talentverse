{
  "features": [
    {
      "name": "text_bm25",
      "params": [
        "keywords"
      ],
      "template": {
        "match": {
          "text": "{{keywords}}"
        }
      }
    },
    {
      "name": "likes_value",
      "template": {
        "field_value_factor": {
          "field": "likes",
          "factor": 0.1
        }
      }
    },
    {
      "name": "comments_value",
      "template": {
        "field_value_factor": {
          "field": "comments",
          "factor": 0.2
        }
      }
    },
    {
      "name": "recency_decay",
      "template": {
        "exp": {
          "ts": {
            "origin": "now",
            "scale": "6h",
            "decay": 0.6
          }
        }
      }
    }
  ]
}