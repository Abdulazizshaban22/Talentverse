generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql"; url = env("DATABASE_URL") }

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("talent")
  createdAt DateTime @default(now())
  points    Int      @default(0)
  profile   Profile?
  applications JobApplication[]
  reviews   ApplicantReview[]
}

model Profile {
  id        String  @id @default(cuid())
  userId    String  @unique
  fullName  String?
  headline  String?
  summary   String?
  location  String?
  cvJson    Json?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  skills    ProfileSkill[]
  education Education[]
  experience Experience[]
}

model Education {
  id        String  @id @default(cuid())
  profileId String
  school    String
  degree    String?
  field     String?
  startDate DateTime?
  endDate   DateTime?
  profile   Profile @relation(fields:[profileId], references:[id])
}

model Experience {
  id        String  @id @default(cuid())
  profileId String
  company   String
  title     String
  startDate DateTime?
  endDate   DateTime?
  summary   String?
  profile   Profile @relation(fields:[profileId], references:[id])
}

model Skill {
  id        String  @id @default(cuid())
  name      String  @unique
  escoId    String? @unique
  kind      String?
  profiles  ProfileSkill[]
  jobs      JobSkill[]
}

model ProfileSkill {
  id        String  @id @default(cuid())
  profileId String
  skillId   String
  weight    Int     @default(1)
  profile   Profile @relation(fields:[profileId], references:[id])
  skill     Skill   @relation(fields:[skillId], references:[id])
  @@unique([profileId, skillId])
}

model Job {
  id        String   @id @default(cuid())
  title     String
  company   String
  description String
  employmentType String?
  createdAt DateTime  @default(now())
  location  String?
  applyUrl  String?
  skills    JobSkill[]
  applications JobApplication[]
}

model JobSkill {
  id      String @id @default(cuid())
  jobId   String
  skillId String
  weight  Int    @default(1)
  job     Job    @relation(fields:[jobId], references:[id])
  skill   Skill  @relation(fields:[skillId], references:[id])
  @@unique([jobId, skillId])
}

model JobApplication {
  id        String   @id @default(cuid())
  jobId     String
  userId    String
  status    String   @default("new") // new | screening | accepted | rejected
  createdAt DateTime @default(now())
  review    ApplicantReview?
  job       Job      @relation(fields:[jobId], references:[id])
  user      User     @relation(fields:[userId], references:[id])
  @@unique([jobId, userId])
}

model ApplicantReview {
  id        String   @id @default(cuid())
  applicationId String @unique
  reviewerId String?
  skills    Int      @default(0)
  experience Int     @default(0)
  culture   Int      @default(0)
  notes     String?
  createdAt DateTime @default(now())
  application JobApplication @relation(fields:[applicationId], references:[id])
  reviewer   User?          @relation(fields:[reviewerId], references:[id])
}

model RankerWeights {
  id        String   @id @default("singleton")
  wGraph    Float    @default(0.5)
  wLTR      Float    @default(0.5)
  updatedAt DateTime @updatedAt
}
