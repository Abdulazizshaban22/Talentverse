DATABASE_URL=postgresql://postgres:postgres@localhost:5432/talent?schema=public

# Auth (Keycloak)
KEYCLOAK_ISSUER=http://localhost:8080/realms/talent
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/talent/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=web

# API/Web Ports
PORT_API=4000
PORT_WEB=3000
NEXT_PUBLIC_API_BASE=http://localhost:4000

# Neo4j (optional GDS)
NEO4J_URL=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=pass
NEO4J_DATABASE=neo4j

# Ranker
AI_MATCH_URL=http://localhost:8600
COMBINE_W_GRAPH=0.5
COMBINE_W_LTR=0.5

# Notifications
RESEND_API_KEY=re_xxx
WHATSAPP_TOKEN=EAAGxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_VERIFY_TOKEN=verify_me

# ESCO
ESCO_API_BASE=https://ec.europa.eu/esco/api
