generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql"; url = env("DATABASE_URL") }

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      String   @default("talent")
  createdAt DateTime @default(now())
  points    Int      @default(0)
  profile   Profile?
  ledger    PointsLedger[]
  messagesFrom Message[] @relation("fromUser")
  messagesTo   Message[] @relation("toUser")
  applications JobApplication[]
  bans      Ban[]
}

model Profile {
  id        String  @id @default(cuid())
  userId    String  @unique
  fullName  String?
  headline  String?
  summary   String?
  location  String?
  cvJson    Json?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  skills    ProfileSkill[]
  education Education[]
  experience Experience[]
}

model Education {
  id        String  @id @default(cuid())
  profileId String
  school    String
  degree    String?
  field     String?
  startDate DateTime?
  endDate   DateTime?
  profile   Profile @relation(fields:[profileId], references:[id])
}

model Experience {
  id        String  @id @default(cuid())
  profileId String
  company   String
  title     String
  startDate DateTime?
  endDate   DateTime?
  summary   String?
  profile   Profile @relation(fields:[profileId], references:[id])
}

model Skill {
  id        String  @id @default(cuid())
  name      String  @unique
  escoId    String? @unique
  kind      String?
  profiles  ProfileSkill[]
  jobs      JobSkill[]
}

model ProfileSkill {
  id        String  @id @default(cuid())
  profileId String
  skillId   String
  weight    Int     @default(1)
  profile   Profile @relation(fields:[profileId], references:[id])
  skill     Skill   @relation(fields:[skillId], references:[id])
  @@unique([profileId, skillId])
}

model Job {
  id        String   @id @default(cuid())
  title     String
  company   String
  description String
  employmentType String?
  createdAt DateTime  @default(now())
  location  String?
  applyUrl  String?
  skills    JobSkill[]
  applications JobApplication[]
}

model JobSkill {
  id      String @id @default(cuid())
  jobId   String
  skillId String
  weight  Int    @default(1)
  job     Job    @relation(fields:[jobId], references:[id])
  skill   Skill  @relation(fields:[skillId], references:[id])
  @@unique([jobId, skillId])
}

model JobApplication {
  id        String   @id @default(cuid())
  jobId     String
  userId    String
  status    String   @default("new")
  createdAt DateTime @default(now())
  job       Job      @relation(fields:[jobId], references:[id])
  user      User     @relation(fields:[userId], references:[id])
  @@unique([jobId, userId])
}

model Challenge {
  id        String   @id @default(cuid())
  title     String
  description String?
  points    Int      @default(50)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Message {
  id          String   @id @default(cuid())
  fromUserId  String
  toUserId    String
  body        String
  createdAt   DateTime @default(now())
  readAt      DateTime?
  flagged     Boolean  @default(false)
  fromUser    User     @relation("fromUser", fields: [fromUserId], references:[id])
  toUser      User     @relation("toUser", fields: [toUserId], references:[id])
}

model Reward {
  id       String  @id @default(cuid())
  title    String
  points   Int
  active   Boolean @default(true)
  createdAt DateTime @default(now())
  redemptions Redemption[]
}

model Coupon {
  id       String  @id @default(cuid())
  code     String  @unique
  percent  Int?
  points   Int?
  active   Boolean @default(true)
  createdAt DateTime @default(now())
}

model Redemption {
  id       String  @id @default(cuid())
  rewardId String
  userId   String
  createdAt DateTime @default(now())
  reward   Reward @relation(fields:[rewardId], references:[id])
}

model PointsLedger {
  id        String   @id @default(cuid())
  userId    String
  delta     Int
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields:[userId], references:[id])
}

model SafetyFlag {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  reason     String
  severity   Int      @default(1)
  createdAt  DateTime @default(now())
}

model Ban {
  id       String   @id @default(cuid())
  userId   String
  until    DateTime
  reason   String
  createdAt DateTime  @default(now())
  user     User      @relation(fields:[userId], references:[id])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String?
  entityType String
  entityId   String
  reason     String
  status     String   @default("open")
  createdAt  DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  data      Json?
  createdAt DateTime @default(now())
}
